// Lấy id từ URL
const params = new URLSearchParams(window.location.search);
const productId = Number(params.get("id"));

// Tìm sản phẩm
const product = products.find(p => p.id === productId);

// Hiển thị thông tin
if(product){

    document.getElementById("product-image").src = product.hinh_anh;

    document.getElementById("product-name").innerText = product.ten;

    document.getElementById("product-price").innerText = product.gia;

    document.getElementById("product-description").innerText = product.description;

    document.getElementById("official-link").href = product.lien_ket;
}

// Xử lý số lượng
const quantityInput = document.getElementById("quantity");

const plusBtn = document.getElementById("plus-btn");
const minusBtn = document.getElementById("minus-btn");

plusBtn.addEventListener("click", () => {
    quantityInput.value = Number(quantityInput.value) + 1;
});

minusBtn.addEventListener("click", () => {

    if(Number(quantityInput.value) > 1){
        quantityInput.value = Number(quantityInput.value) - 1;
    }

});